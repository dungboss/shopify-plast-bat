{%- comment -%}
  Renders the text with icons section.

  Accepts:
  - divider {boolean} - Whether to show a divider
  - title {string} - The title of the section
  - align_text {'left'|'center'|'right'} - The alignment of the text
  - heading_size {'h0'|'h1'|'h2'|'h3'} - The size of the heading
  - button_label {string} - The label of the button
  - button_link {string} - The link of the button
  - icon_color {color} - The color of the icons
  - icon_weight {string} - The weight of the icons
  - desktop_columns_per_row {number} - The number of columns per row on desktop

  Usage:
  {% render 'section-text-with-icons' %}
{%- endcomment -%}

{%- liquid
  assign divider = divider | default: section.settings.divider, allow_false: true | default: false, allow_false: true
  assign title = title | default: section.settings.title | default: blank
  assign align_text = align_text | default: section.settings.align_text | default: 'center'
  assign heading_size = heading_size | default: section.settings.heading_size | default: 'h2'
  assign button_label = button_label | default: section.settings.button_label | default: blank
  assign button_link = button_link | default: section.settings.button_link | default: blank
  assign icon_color = icon_color | default: section.settings.icon_color | default: '#000'
  assign icon_weight = icon_weight | default: settings.icon_weight | default: '5px'
  assign desktop_columns_per_row = desktop_columns_per_row | default: section.settings.desktop_columns_per_row | default: 3
  assign show_center_image = section.settings.show_center_image | default: false
  assign center_image = section.settings.center_image
  if center_image == blank and product != blank
    assign _ci = section.settings.center_image_product_index | default: 1
    assign center_image = product.images[_ci]
  endif
  assign half_count = section.blocks.size | divided_by: 2
-%}

{%- if divider -%}<div class="section--divider">{%- endif -%}

<div
  class="text-with-icons"
  data-section-id="{{ section.id }}"
  data-section-type="text-with-icons"
>
  <div class="page-width">
    {%- if title != blank -%}
      <div
        class="
          text-with-icons__title
          section-header
        "
      >
        <h2 class="text-{{ align_text }} {% if heading_size %}{{ heading_size }}{% endif %}">{{ title | escape }}</h2>
      </div>
    {%- endif -%}
    {%- if show_center_image and center_image != blank -%}
      {%- comment -%} 3-column layout: left blocks | center image | right blocks {%- endcomment -%}
      <div class="text-with-icons__center-layout">
        <div class="text-with-icons__center-col text-with-icons__center-col--left">
          {% for block in section.blocks %}
            {%- if forloop.index0 < half_count -%}
              <div class="text-with-icons__block text-{{ align_text }}" {{ block.shopify_attributes }}>
                <div class="text-with-icons__block-icon">
                  {% render 'icon', name: block.settings.icon, library: 'tcwi' %}
                </div>
                <div class="text-with-icons__block-title"><h3>{{ block.settings.title }}</h3></div>
                <div class="text-with-icons__block-text">{{ block.settings.text }}</div>
              </div>
            {%- endif -%}
          {% endfor %}
        </div>
        <div class="text-with-icons__center-col text-with-icons__center-col--image">
          <div class="text-with-icons__center-image">
            {%- render 'image-element',
              img: center_image,
              widths: '300, 400, 500',
              classes: 'text-with-icons__center-img'
            -%}
          </div>
        </div>
        <div class="text-with-icons__center-col text-with-icons__center-col--right">
          {% for block in section.blocks %}
            {%- if forloop.index0 >= half_count -%}
              <div class="text-with-icons__block text-{{ align_text }}" {{ block.shopify_attributes }}>
                <div class="text-with-icons__block-icon">
                  {% render 'icon', name: block.settings.icon, library: 'tcwi' %}
                </div>
                <div class="text-with-icons__block-title"><h3>{{ block.settings.title }}</h3></div>
                <div class="text-with-icons__block-text">{{ block.settings.text }}</div>
              </div>
            {%- endif -%}
          {% endfor %}
        </div>
      </div>
    {%- else -%}
    <div
      class="
        text-with-icons__blocks
        has-{{ desktop_columns_per_row }}-per-row
      "
      data-block-count="{{ section.blocks.size }}"
    >
      {% for block in section.blocks %}
        <div class="text-with-icons__block text-{{ align_text }}" {{ block.shopify_attributes }}>
          <div class="text-with-icons__block-icon">
            {% render 'icon', name: block.settings.icon, library: 'tcwi' %}
          </div>
          <div class="text-with-icons__block-title">
            <h3>{{ block.settings.title }}</h3>
          </div>
          <div class="text-with-icons__block-text">
            {{ block.settings.text }}
          </div>
        </div>
      {% endfor %}
    </div>
    {%- endif -%}

    {%- if button_label != blank -%}
      <div class="text-with-icons__button">
        <a href="{{ button_link }}" class="btn btn--secondary">
          {{ button_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{%- if divider -%}</div>{%- endif -%}

{% style %}
  #shopify-section-{{ section.id }} .icon {
    color: {{ icon_color }};
  }

  #shopify-section-{{ section.id }} .icon path,
  #shopify-section-{{ section.id }} .icon polygon,
  #shopify-section-{{ section.id }} .icon rect,
  #shopify-section-{{ section.id }} .icon circle,
  #shopify-section-{{ section.id }} .icon ellipse,
  #shopify-section-{{ section.id }} .icon line,
  #shopify-section-{{ section.id }} .icon polyline,
  #shopify-section-{{ section.id }} .icon g {
    stroke-width: {{ icon_weight | replace: 'px', '' | minus: 1 }}px;
  }

  /* 3-column layout with center image */
  #shopify-section-{{ section.id }} .text-with-icons__center-layout {
    display: flex;
    align-items: center;
    gap: 24px;
  }
  #shopify-section-{{ section.id }} .text-with-icons__center-col--left,
  #shopify-section-{{ section.id }} .text-with-icons__center-col--right {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  #shopify-section-{{ section.id }} .text-with-icons__center-col--image {
    flex: 0 0 280px;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .text-with-icons__center-image {
    border-radius: 50%;
    overflow: hidden;
    width: 280px;
    height: 280px;
    margin: 0 auto;
  }
  #shopify-section-{{ section.id }} .text-with-icons__center-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Mobile: stack vertically, image in the middle */
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .text-with-icons__center-layout {
      flex-direction: column;
    }
    #shopify-section-{{ section.id }} .text-with-icons__center-col--left,
    #shopify-section-{{ section.id }} .text-with-icons__center-col--right {
      width: 100%;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 16px;
    }
    #shopify-section-{{ section.id }} .text-with-icons__center-col--left .text-with-icons__block,
    #shopify-section-{{ section.id }} .text-with-icons__center-col--right .text-with-icons__block {
      flex: 1 1 calc(50% - 8px);
      min-width: 140px;
    }
    #shopify-section-{{ section.id }} .text-with-icons__center-col--image {
      order: -1;
    }
    #shopify-section-{{ section.id }} .text-with-icons__center-image {
      width: 220px;
      height: 220px;
    }
  }
{% endstyle %}
